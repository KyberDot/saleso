# eBay API Credentials
EBAY_CLIENT_ID=your_app_id_here
EBAY_CLIENT_SECRET=your_cert_id_here
EBAY_REDIRECT_URI=https://saleso.vexyo.app/auth/ebay/callback
EBAY_ENV=production

# Security
SESSION_SECRET=run_openssl_rand_-hex_32_here

# URLs
FRONTEND_URL=https://saleso.vexyo.app
VITE_API_URL=https://saleso.vexyo.app

# eBay Deletion Notification (compliance requirement)
# Register https://yourdomain.com/api/auth/ebay-deletion in eBay developer portal
EBAY_DELETION_TOKEN=generate-a-random-secret-string-here
EBAY_DELETION_ENDPOINT=https://saleso.vexyo.app/api/auth/ebay-deletion

# GitHub (for pulling images)
GITHUB_REPOSITORY=kyberdot/saleso
